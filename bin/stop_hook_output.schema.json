{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "reason",
    "continuation_message",
    "speak",
    "next_ticket_id",
    "next_phase"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "continue_same_ticket",
        "route_to_orchestrator",
        "block_for_user",
        "next_ticket",
        "stop"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "continuation_message": {
      "type": "string"
    },
    "speak": {
      "type": "string"
    },
    "next_ticket_id": {
      "type": "string"
    },
    "next_phase": {
      "type": "string",
      "enum": [
        "",
        "planning",
        "building",
        "documenting",
        "done",
        "none"
      ]
    },
    "overall_score": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "evidence_quality": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "integration_readiness": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "traceability": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "freshness": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "rerun_required": {
      "type": "boolean"
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
