{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/bin/capture_user_turn.py\"",
            "statusMessage": "Capturing current-turn user intent",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/hooks/aikage_ping.py\"",
            "statusMessage": "Sending Aikage heartbeat",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/bin/stop_hook.py\"",
            "statusMessage": "Evaluating Ralph stop hook",
            "timeout": 90
          }
        ]
      }
    ]
  }
}
