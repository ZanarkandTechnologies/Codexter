{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/bin/capture_user_turn.py\"",
            "statusMessage": "Capturing current-turn user intent",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/hooks/farplane_console_ping.py\"",
            "statusMessage": "Sending Farplane Console start heartbeat",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/bin/stop_hook.py\"",
            "statusMessage": "Evaluating Ralph stop hook",
            "timeout": 90
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/hooks/farplane_console_ping.py\"",
            "statusMessage": "Sending Farplane Console stop heartbeat",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
