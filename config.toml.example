# Managed template for ~/.codex/config.toml.
# Do not put machine-local secrets or trust entries here.
# `install.sh` renders this template using values from:
#   - ~/.codex/config.local.env
#   - ~/.codex/config.local.toml (optional, appended verbatim)

model = "gpt-5.5"
approval_policy = "never"
sandbox_mode = "danger-full-access"
model_reasoning_effort = "medium"
notify = ["python3", "__CODEX_HOME__/bin/notify.py"]
approvals_reviewer = "user"
service_tier = "fast"

[features]
multi_agent = true

[env]
FARPLANE_HOME = "__CODEX_HOME__"
FARPLANE_IMPL_HOOK = "1"
# Optional hosted telemetry for hook activity. Leave unset until your backend exists.
# FARPLANE_TELEMETRY_API_URL = "https://your-backend.example.com/api/codex/activity"
# FARPLANE_TELEMETRY_API_TOKEN = "replace-me"
# FARPLANE_TELEMETRY_TIMEOUT_SECS = "2.0"
# Hook-backed skill-opportunity proposer. Captured windows stay local under
# `.farplane/state/self-improve/`. The Stop hook launches a background
# fire-and-forget Codex job every interval by default. The job creates Notion
# approval tasks tagged as agent self-improvement; it does not edit skills.
# Set FARPLANE_SKILL_OPPORTUNITY_APPLY = "0" locally to disable it.
FARPLANE_SKILL_OPPORTUNITY_APPLY = "1"
FARPLANE_SKILL_OPPORTUNITY_APPLY_INTERVAL = "10"
FARPLANE_SKILL_OPPORTUNITY_MAX_EXCHANGES = "10"
FARPLANE_SKILL_OPPORTUNITY_RECENT_SESSIONS = "5"
# Set this locally from ~/.codex/private/docs/notion.md when Notion task
# proposals should be enabled.
# FARPLANE_SKILL_OPPORTUNITY_NOTION_TASKS_DATA_SOURCE = "collection://your-tasks-data-source"
FARPLANE_SKILL_OPPORTUNITY_NOTION_TAG = "agent self improvement"
FARPLANE_SKILL_OPPORTUNITY_NOTION_STATUS = "Review"
# FARPLANE_SKILL_OPPORTUNITY_APPLY_DRY_RUN = "1"
# Optional explicit force-on for Farplane hook behavior. The Stop hook also
# auto-activates from clear runtime context such as `.farplane/`, `tickets/`,
# `IMPL_RESULT`, or explicit ticket selectors.
# Keep machine-specific hook tuning local if you need non-default behavior.

[sandbox_workspace_write]
network_access = false
exclude_tmpdir_env_var = false
exclude_slash_tmp = false

[mcp_servers.convex]
command = "npx"
args = ["-y", "convex", "mcp", "start"]

[mcp_servers.sequential-thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]

# Add your real Ref key locally only.
[mcp_servers.Ref]
url = "https://api.ref.tools/mcp?apiKey=__REF_API_KEY__"

[mcp_servers.deepwiki]
url = "https://mcp.deepwiki.com/mcp"

[mcp_servers.grep]
url = "https://mcp.grep.app"

[mcp_servers.notion]
command = "npx"
args = ["-y", "@notionhq/notion-mcp-server"]

[mcp_servers.notion.env]
NOTION_TOKEN = "__NOTION_TOKEN__"

[agents]
max_threads = 6
max_depth = 1

[agents.asset-generator]
description = "Asset generation subagent for game/app art using Replicate MCP (and Fal AI references). Generates multiple options, saves them to assets/generated/, and reports choices."
config_file = "agents/asset-generator.toml"

[agents.bash-operator]
description = "Specialist shell operator for filesystem/build/debug command workflows. Use proactively for multi-step terminal tasks that need efficient command selection, safety checks, verification, and rollback notes."
config_file = "agents/bash-operator.toml"

[agents.reviewer]
description = "Independent rubric reviewer for ticketed plans, implementations, evidence bundles, skills, prompts, docs, evals, and completion receipts. Use proactively before material completion claims."
config_file = "agents/reviewer.toml"

[agents.orchestrator]
description = "Stop-hook orchestrator for ticket handoff, continuation, and next-ticket routing."
config_file = "agents/orchestrator.toml"

[agents.documentation-maintainer]
description = "Meta-agent responsible for keeping the system's documentation (README, CHANGELOG) accurate and up-to-date by synthesizing recent research and project progress."
config_file = "agents/documentation-maintainer.toml"

[agents.documentation-searcher]
description = "Specialist agent for fetching and synthesizing official documentation from specific URLs using Ref tools."
config_file = "agents/documentation-searcher.toml"

[agents.explore]
description = "Combined agent for exploring local codebases. Handles locating files, analyzing implementations, and finding code patterns. Use for WHERE, HOW, or SHOW ME questions."
config_file = "agents/explore.toml"

[agents.frontend-designer]
description = "Expert UI/UX designer for both app interfaces (shadcn, AI Elements) and cinematic landing pages (scroll narratives, WebGL). Creates distinctive designs that avoid AI-generated aesthetics."
config_file = "agents/frontend-designer.toml"

[agents.librarian]
description = "Agent for exploring external codebases and patterns. Handles broad GitHub searches (DISCOVER) and deep-dives into specific repositories."
config_file = "agents/librarian.toml"

[agents.qa-tester]
description = "QA subagent that plans and executes tests. Keeps the agent prompt thin by delegating detailed workflows to Skills (Playwright, agent-browser, cinematic landing testing)."
config_file = "agents/qa-tester.toml"

[agents.completion-reviewer]
description = "Stop-hook reviewer for missing-result impl continuation checks."
config_file = "agents/completion-reviewer.toml"

[agents.skill-opportunity-applier]
description = "Hook sidecar that turns recent conversation windows into Notion approval tasks for agent self-improvement."
config_file = "agents/skill-opportunity-applier.toml"

[agents.repent-scribe]
description = "Post-fix repent lesson scribe that writes LESSONS rows and optional Notion improvement proposals."
config_file = "agents/repent-scribe.toml"

[agents.hardcase-curator]
description = "Sanitized hard-case curator for corrected repent episodes that may become eval or training-data samples."
config_file = "agents/hardcase-curator.toml"

[notice]
hide_rate_limit_model_nudge = true
hide_full_access_warning = true

[notice.model_migrations]
"gpt-5.3-codex" = "gpt-5.5"
"gpt-5.4" = "gpt-5.5"

# Keep machine-specific trust entries local only in `~/.codex/config.local.toml`.

[tui]
status_line = ["model-with-reasoning", "context-remaining", "current-dir", "five-hour-limit", "session-id"]
