{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ralph Judge Verdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ticket_id",
    "current_phase",
    "decision",
    "reason",
    "orchestrator_message",
    "evidence_ok"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "ticket_id": {
      "type": "string",
      "pattern": "^TASK-\\d{4}$"
    },
    "current_phase": {
      "type": "string",
      "enum": [
        "planning",
        "building",
        "documenting"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "repeat_ralphplan",
        "repeat_ralph",
        "advance_ticket",
        "block_ticket",
        "complete_ticket",
        "escalate_to_operator"
      ]
    },
    "next_phase": {
      "type": "string",
      "enum": [
        "planning",
        "building",
        "documenting",
        "done",
        "none"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "orchestrator_message": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ok": {
      "type": "boolean"
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_gate_failures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
