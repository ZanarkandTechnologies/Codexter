{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ralph Run State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "ticket_id",
    "ticket_path",
    "phase",
    "status",
    "attempt",
    "skill_name",
    "compute_class",
    "parallel_slots_reserved",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "ticket_id": {
      "type": "string",
      "pattern": "^TASK-\\d{4}$"
    },
    "ticket_path": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "planning",
        "building",
        "documenting"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "waiting_for_judge",
        "waiting_for_worker",
        "blocked",
        "complete",
        "failed",
        "cancelled"
      ]
    },
    "session_id": {
      "type": "string"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "skill_name": {
      "type": "string",
      "enum": ["ralplan", "ralph", "docs-closeout"]
    },
    "compute_class": {
      "type": "string",
      "enum": [
        "local",
        "local_worktree",
        "remote_vm",
        "remote_container"
      ]
    },
    "executor_target": {
      "type": "string"
    },
    "tmux_session": {
      "type": "string"
    },
    "tmux_window": {
      "type": "string"
    },
    "tmux_pane": {
      "type": "string"
    },
    "auto_continue": {
      "type": "boolean"
    },
    "parallel_slots_reserved": {
      "type": "integer",
      "minimum": 1
    },
    "last_worker_result": {
      "type": "string"
    },
    "last_judge_verdict": {
      "type": "string"
    },
    "last_hook_decision": {
      "type": "string"
    },
    "last_hook_summary": {
      "type": "string"
    },
    "last_hook_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "last_user_turn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn_id",
        "captured_at",
        "source",
        "raw_text",
        "intent_mode",
        "requested_outcome",
        "explicit_ticket_id",
        "hard_constraints",
        "summary"
      ],
      "properties": {
        "turn_id": {
          "type": "string",
          "minLength": 1
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "raw_text": {
          "type": "string",
          "minLength": 1
        },
        "intent_mode": {
          "type": "string",
          "enum": [
            "planning",
            "building",
            "documenting",
            "question",
            "backlog",
            "unknown"
          ]
        },
        "requested_outcome": {
          "type": "string",
          "enum": [
            "ticket_plan",
            "code_change",
            "docs_update",
            "review_or_analysis",
            "answer_only",
            "unknown"
          ]
        },
        "explicit_ticket_id": {
          "type": "string"
        },
        "hard_constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ticket_local_only",
              "no_edits",
              "source_required",
              "specific_ticket_required"
            ]
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "last_intent_alignment": {
      "type": "string",
      "enum": [
        "aligned",
        "soft_mismatch",
        "hard_mismatch",
        "unknown"
      ]
    },
    "last_intent_alignment_reason": {
      "type": "string"
    },
    "last_intent_turn_id": {
      "type": "string"
    },
    "next_phase": {
      "type": "string",
      "enum": [
        "planning",
        "building",
        "documenting",
        "done",
        "none"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
