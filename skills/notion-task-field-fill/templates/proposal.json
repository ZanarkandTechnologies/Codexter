{
  "run": {
    "id": "<run-id>",
    "mode": "dry-run",
    "window": {
      "start": "<iso-datetime>",
      "end": "<iso-datetime>",
      "timezone": "Asia/Kuala_Lumpur"
    },
    "target_fields": [
      "Act Time",
      "Project",
      "Areas",
      "Attention Required",
      "Tags"
    ],
    "connector_status": {
