prefix_rule(pattern=["curl", "-i", "-X", "POST", "http://127.0.0.1:3003/api/agent-search"], decision="allow")
prefix_rule(pattern=["curl", "-i", "http://127.0.0.1:3003/api/agent-search"], decision="allow")
prefix_rule(pattern=["curl", "-i", "http://127.0.0.1:3004/api/agent-search"], decision="allow")
prefix_rule(pattern=["curl", "-v", "--max-time", "3", "http://127.0.0.1:3004/api/agent-search"], decision="allow")
