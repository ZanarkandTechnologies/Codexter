prefix_rule(pattern=["curl", "-i", "-X", "OPTIONS", "-H", "Origin: https://example.com", "-H", "Access-Control-Request-Method: POST", "-H", "Access-Control-Request-Headers: content-type", "https://cryolens-c5ele7c46-kenjipcxs-projects.vercel.app/api/agent-search"], decision="allow")
prefix_rule(pattern=["curl", "-i", "--max-time", "10", "-X", "POST", "-H", "Origin: https://example.com", "-H", "content-type: application/json", "-d", "{\"prompt\":\"What is VS55?\",\"profile\":\"research\"}", "https://cryolens-c5ele7c46-kenjipcxs-projects.vercel.app/api/agent-search"], decision="allow")
prefix_rule(pattern=["pgrep", "-af", "dev-agent-api|vercel dev|vite --host 127.0.0.1 --port 5173"], decision="allow")
prefix_rule(pattern=["git", "clone"], decision="allow")
prefix_rule(pattern=["node", "--experimental-strip-types", "--input-type=module", "-e", "import handler from \"./frontend/lib/agent-search-route-local.ts\"; const response = await handler(new Request(\"http://localhost/api/agent-search\", { method: \"POST\", headers: {\"content-type\":\"application/json\"}, body: JSON.stringify({ prompt: \"What is VS55? Keep it brief.\", profile: \"research\" }) })); const reader = response.body.getReader(); const decoder = new TextDecoder(); let buffer = \"\"; while (true) { const {done, value} = await reader.read(); if (done) break; buffer += decoder.decode(value, {stream:true}); const chunks = buffer.split(\"\\n\\n\"); buffer = chunks.pop() ?? \"\"; for (const chunk of chunks) { if (chunk.includes(\"message-debug\")) console.log(chunk); } } if (buffer.includes(\"message-debug\")) console.log(buffer);"], decision="allow")
prefix_rule(pattern=["node", "--experimental-strip-types", "--input-type=module", "-e", "import handler from \"./frontend/lib/agent-search-route-local.ts\"; const response = await handler(new Request(\"http://localhost/api/agent-search\", { method: \"POST\", headers: {\"content-type\":\"application/json\"}, body: JSON.stringify({ prompt: \"What is VS55? Keep it brief.\", profile: \"research\" }) })); const reader = response.body.getReader(); const decoder = new TextDecoder(); let buffer = \"\"; let sawOutput = false; while (true) { const {done, value} = await reader.read(); if (done) break; buffer += decoder.decode(value, {stream:true}); const chunks = buffer.split(\"\\n\\n\"); buffer = chunks.pop() ?? \"\"; for (const chunk of chunks) { if (chunk.includes(type:tool_output)) { console.log(chunk); sawOutput = true; process.exit(0); } } } if (buffer.includes(type:tool_output)) { console.log(buffer); sawOutput = true; } if (!sawOutput) { process.exit(1); }"], decision="allow")
prefix_rule(pattern=["node", "--experimental-strip-types", "--input-type=module", "-e", "import handler from \"./frontend/lib/agent-search-route-local.ts\"; const response = await handler(new Request(\"http://localhost/api/agent-search\", { method: \"POST\", headers: {\"content-type\":\"application/json\"}, body: JSON.stringify({ prompt: \"What is VS55? Keep it brief.\", profile: \"research\" }) })); const reader = response.body.getReader(); const decoder = new TextDecoder(); let buffer = \"\"; outer: while (true) { const {done, value} = await reader.read(); if (done) break; buffer += decoder.decode(value, {stream:true}); const chunks = buffer.split(\"\\n\\n\"); buffer = chunks.pop() ?? \"\"; for (const chunk of chunks) { if (chunk.includes(\"\\\"type\\\":\\\"tool_output\\\"\")) { console.log(chunk); break outer; } } }"], decision="allow")
prefix_rule(pattern=["pgrep", "-af", "dev-agent-api|vercel dev|vite --host 127.0.0.1 --port 5173|experimental-strip-types --input-type=module"], decision="allow")
