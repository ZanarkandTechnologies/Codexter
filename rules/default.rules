prefix_rule(pattern=["curl", "-i", "--max-time", "5", "-X", "POST", "-H", "Origin: http://localhost:3000", "-H", "content-type: application/json", "-d", "{\"prompt\":\"hi\",\"profile\":\"research\"}", "http://127.0.0.1:3210/api/agent-search"], decision="allow")
prefix_rule(pattern=["vercel", "deploy"], decision="allow")
prefix_rule(pattern=["curl", "-i", "-X", "OPTIONS", "-H", "Origin: https://example.com", "-H", "Access-Control-Request-Method: POST", "-H", "Access-Control-Request-Headers: content-type", "https://cryolens-1k3ygmfgy-kenjipcxs-projects.vercel.app/api/agent-search"], decision="allow")
