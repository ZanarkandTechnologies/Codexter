prefix_rule(pattern=["/bin/bash", "-lc", "AGENT_API_PORT=3211 node --experimental-strip-types ./frontend/scripts/dev-agent-api.ts >/tmp/agent-api-3211.log 2>&1 & pid=$!; sleep 2; curl -i --max-time 10 -H 'Origin: http://127.0.0.1:3000' http://127.0.0.1:3211/api/agent-search; status=$?; kill $pid >/dev/null 2>&1 || true; echo \"\\n--- CURL STATUS: $status ---\"; echo \"--- SERVER LOG ---\"; cat /tmp/agent-api-3211.log"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "AGENT_API_PORT=3211 node --experimental-strip-types ./frontend/scripts/dev-agent-api.ts >/tmp/agent-api-3211.log 2>&1 & pid=$!; sleep 2; curl -N --max-time 20 -H 'Origin: http://127.0.0.1:3000' -H 'content-type: application/json' -d '{\"prompt\":\"What is VS55?\",\"profile\":\"research\"}' http://127.0.0.1:3211/api/agent-search; status=$?; kill $pid >/dev/null 2>&1 || true; echo \"\\n--- CURL STATUS: $status ---\"; echo \"--- SERVER LOG ---\"; cat /tmp/agent-api-3211.log"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "AGENT_API_PORT=3212 node --experimental-strip-types ./frontend/scripts/dev-agent-api.ts >/tmp/agent-api-3212.log 2>&1 & pid=$!; sleep 2; curl -N --max-time 90 -H 'Origin: http://127.0.0.1:3000' -H 'content-type: application/json' -d '{\"prompt\":\"What is VS55? Answer in 2 short paragraphs.\",\"profile\":\"research\"}' http://127.0.0.1:3212/api/agent-search > /tmp/agent-api-3212-stream.txt; status=$?; kill $pid >/dev/null 2>&1 || true; echo \"--- CURL STATUS: $status ---\"; tail -n 40 /tmp/agent-api-3212-stream.txt; echo \"--- SERVER LOG ---\"; cat /tmp/agent-api-3212.log"], decision="allow")
prefix_rule(pattern=["pgrep", "-af", "node --experimental-strip-types ./scripts/dev-agent-api.ts"], decision="allow")
