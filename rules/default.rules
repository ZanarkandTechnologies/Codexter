prefix_rule(pattern=["printf", "\\n---\\n"], decision="allow")
prefix_rule(pattern=["npx", "@biomejs/biome", "check", "--files-ignore-unknown=true", "cli/cli-utils.ts", "cli/onboarding-commands.ts", "cli/ui-commands.ts", "cli/ui-commands.test.ts", "cli/shellcorp-cli.ts", "README.md", "docs/public-docs/getting-started.md", "docs/HISTORY.md", "docs/MEMORY.md"], decision="allow")
prefix_rule(pattern=["npx", "@biomejs/biome", "check", "--files-ignore-unknown=true", "cli/onboarding-commands.ts", "cli/ui-commands.ts", "cli/ui-commands.test.ts", "README.md", "docs/public-docs/getting-started.md", "docs/HISTORY.md", "docs/MEMORY.md"], decision="allow")
