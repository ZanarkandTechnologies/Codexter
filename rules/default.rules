# ~/.codex/rules/default.rules
# Command approval rules for Codex.
# Syntax: prefix_rule(pattern, decision, justification, match?, not_match?)
# decision = "allow" | "prompt" | "forbidden"
#
# Read-only / inspection commands run without prompting.
# Anything mutating or potentially destructive prompts first.

# ---------------------------------------------------------------------------
# Git — read-only ops: allow
# ---------------------------------------------------------------------------
prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Read-only status check",
)
prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
    justification = "Read-only history",
)
prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Read-only diff",
)
prefix_rule(
    pattern = ["git", "show"],
    decision = "allow",
    justification = "Read-only object inspection",
)
prefix_rule(
    pattern = ["git", "branch"],
    decision = "allow",
    justification = "Read-only branch listing",
)
prefix_rule(
    pattern = ["git", "stash", "list"],
    decision = "allow",
    justification = "Read-only stash listing",
)
prefix_rule(
    pattern = ["git", "remote"],
    decision = "allow",
    justification = "Read-only remote listing",
)
prefix_rule(
    pattern = ["git", "tag"],
    decision = "allow",
    justification = "Read-only tag listing",
)

# ---------------------------------------------------------------------------
# Git — writing ops: prompt before running
# ---------------------------------------------------------------------------
prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Creates a commit — verify message and scope before proceeding",
)
prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Writes to remote — verify branch and force flags",
)
prefix_rule(
    pattern = ["git", "reset"],
    decision = "prompt",
    justification = "Can discard commits or staged changes",
)
prefix_rule(
    pattern = ["git", "rebase"],
    decision = "prompt",
    justification = "Rewrites history — verify base and conflict strategy",
)
prefix_rule(
    pattern = ["git", "merge"],
    decision = "prompt",
    justification = "Merges branches — verify target branch",
)
prefix_rule(
    pattern = ["git", "checkout"],
    decision = "prompt",
    justification = "Switches branch or restores files",
)
prefix_rule(
    pattern = ["git", "switch"],
    decision = "prompt",
    justification = "Switches branch",
)
prefix_rule(
    pattern = ["git", "stash"],
    decision = "prompt",
    justification = "Stashes or applies changes",
)
prefix_rule(
    pattern = ["git", "clean"],
    decision = "prompt",
    justification = "Deletes untracked files — verify scope",
)

# ---------------------------------------------------------------------------
# Shell — safe read-only commands: allow
# ---------------------------------------------------------------------------
prefix_rule(
    pattern = ["ls"],
    decision = "allow",
    justification = "Directory listing",
)
prefix_rule(
    pattern = ["pwd"],
    decision = "allow",
    justification = "Print working directory",
)
prefix_rule(
    pattern = ["echo"],
    decision = "allow",
    justification = "Print text",
)
prefix_rule(
    pattern = ["cat"],
    decision = "allow",
    justification = "Read file contents",
)
prefix_rule(
    pattern = ["head"],
    decision = "allow",
    justification = "Read first lines of file",
)
prefix_rule(
    pattern = ["tail"],
    decision = "allow",
    justification = "Read last lines of file",
)
prefix_rule(
    pattern = ["wc"],
    decision = "allow",
    justification = "Word/line count",
)
prefix_rule(
    pattern = ["rg"],
    decision = "allow",
    justification = "Ripgrep search — read-only",
)
prefix_rule(
    pattern = ["grep"],
    decision = "allow",
    justification = "Grep search — read-only",
)

# ---------------------------------------------------------------------------
# Shell — destructive ops: prompt
# ---------------------------------------------------------------------------
prefix_rule(
    pattern = ["rm"],
    decision = "prompt",
    justification = "Deletes files — verify scope before proceeding",
    match = ["rm file.txt", "rm -rf dist/"],
)
prefix_rule(
    pattern = ["mv"],
    decision = "prompt",
    justification = "Moves or renames files — can overwrite",
)
prefix_rule(
    pattern = ["cp"],
    decision = "allow",
    justification = "Copies files — generally safe",
)
prefix_rule(
    pattern = ["chmod"],
    decision = "prompt",
    justification = "Changes file permissions",
)
prefix_rule(
    pattern = ["chown"],
    decision = "prompt",
    justification = "Changes file ownership",
)
prefix_rule(
    pattern = ["sudo"],
    decision = "prompt",
    justification = "Elevated privileges — always verify",
)
prefix_rule(
    pattern = ["kill"],
    decision = "prompt",
    justification = "Terminates processes",
)
prefix_rule(
    pattern = ["pkill"],
    decision = "prompt",
    justification = "Terminates processes by name",
)

# ---------------------------------------------------------------------------
# Package managers: prompt for installs, allow reads
# ---------------------------------------------------------------------------
prefix_rule(
    pattern = ["npm", "install"],
    decision = "prompt",
    justification = "Installs packages — verify dependency list",
)
prefix_rule(
    pattern = ["npm", "uninstall"],
    decision = "prompt",
    justification = "Removes packages",
)
prefix_rule(
    pattern = ["pnpm", "install"],
    decision = "prompt",
    justification = "Installs packages — verify dependency list",
)
prefix_rule(
    pattern = ["pnpm", "add"],
    decision = "prompt",
    justification = "Adds a package dependency",
)
prefix_rule(
    pattern = ["pnpm", "remove"],
    decision = "prompt",
    justification = "Removes a package dependency",
)
prefix_rule(
    pattern = ["npm", "run"],
    decision = "allow",
    justification = "Runs a script defined in package.json",
)
prefix_rule(
    pattern = ["pnpm", "run"],
    decision = "allow",
    justification = "Runs a script defined in package.json",
)

# ---------------------------------------------------------------------------
# GitHub CLI: read ops allow, write ops prompt
# ---------------------------------------------------------------------------
prefix_rule(
    pattern = ["gh", "pr", "view"],
    decision = "allow",
    justification = "Read-only PR inspection",
)
prefix_rule(
    pattern = ["gh", "pr", "list"],
    decision = "allow",
    justification = "Read-only PR listing",
)
prefix_rule(
    pattern = ["gh", "issue", "list"],
    decision = "allow",
    justification = "Read-only issue listing",
)
prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "prompt",
    justification = "Opens a pull request — verify title, body, and target",
)
prefix_rule(
    pattern = ["gh", "pr", "merge"],
    decision = "prompt",
    justification = "Merges a PR — irreversible",
)
prefix_rule(pattern=["npx", "@biomejs/biome", "check", "--write", "--unsafe", "--files-ignore-unknown=true", "cli/cli-utils.ts", "cli/onboarding-commands.ts"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "npm run typecheck >/tmp/shellcorp-typecheck.log && tail -n 5 /tmp/shellcorp-typecheck.log"], decision="allow")
prefix_rule(pattern=["printf", "\\n--- UI PACKAGE ---\\n"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "git reset -- ui/src/features/office-system/components/employee/index.tsx ui/src/features/office-system/components/employee/use-employee-locomotion.ts ui/src/features/office-system/components/employee/employee-motion.ts ui/src/features/office-system/components/employee/employee-motion.test.ts docs/HISTORY.md docs/MEMORY.md >/dev/null 2>&1 || true && git add ui/src/features/office-system/components/employee/index.tsx ui/src/features/office-system/components/employee/use-employee-locomotion.ts ui/src/features/office-system/components/employee/employee-motion.ts ui/src/features/office-system/components/employee/employee-motion.test.ts && git diff --cached --name-only"], decision="allow")
